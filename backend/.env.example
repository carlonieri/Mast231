# ==== Server ====
PORT=3000
NODE_ENV=development

# ==== Database (PostgreSQL) ====
# Connessione autenticata e cifrata in transito (in produzione richiedere sslmode=require)
DATABASE_URL=postgresql://user:password@localhost:5432/mast231

# ==== Claude API (classificazione email inviate/ricevute) ====
ANTHROPIC_API_KEY=

# ==== Casella email cliente (IMAP — Aruba, non Microsoft 365) ====
# La casella è ospitata su Aruba (hosting nativo, non Microsoft 365): il collegamento
# è IMAP standard (host/porta/utente/password), non Microsoft Graph/OAuth.
# VINCOLO DI SICUREZZA NON NEGOZIABILE: nessuna credenziale SMTP viene mai configurata,
# quindi il sistema non può fisicamente inviare email. L'unica scrittura IMAP consentita
# è generare bozze nella cartella Bozze (destinatari precompilati, mai testo né invio):
# vedi backend/src/services/imap-draft.service.js. Ogni altra operazione IMAP è sola lettura.
IMAP_HOST=imaps.aruba.it
IMAP_PORT=993
IMAP_TLS=true
IMAP_USER=
# In produzione non tenere la password in chiaro in .env: usare un secret manager o
# storage cifrato. In locale il file .env resta comunque escluso da git (vedi .gitignore).
IMAP_PASSWORD=
IMAP_INBOX_FOLDER=INBOX
IMAP_SENT_FOLDER=Posta Inviata
IMAP_DRAFTS_FOLDER=Bozze

# ==== Autenticazione web app (login gestionale) ====
SESSION_SECRET=

# ==== Configurazione business (valori di default) ====
# Giorni senza risposta dopo cui un contatto viene proposto per il richiamo
FOLLOWUP_DAYS_THRESHOLD=7
# Numero massimo di destinatari per bozza generata dal caricamento lista giornaliera
UPLOAD_BATCH_SIZE=150
